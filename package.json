{
  "name": "carecareer",
  "version": "0.1.0",
  "private": true,
  "description": "CareCareer AI-Native Healthcare Workforce Platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "db:reset": "turbo run db:reset",
    "security:secrets": "gitleaks detect --source .",
    "security:dependencies": "pnpm audit --audit-level high",
    "generate:service": "tsx tooling/generators/service/generate.ts",
    "demo:up": "node scripts/demo-up.mjs",
    "demo:down": "node scripts/demo-down.mjs",
    "demo:reset": "node scripts/demo-reset.mjs",
    "demo:e2e": "pnpm --filter @carecareer/platform-admin-console e2e",
    "demo:e2e:headed": "pnpm --filter @carecareer/platform-admin-console e2e:headed",
    "demo:e2e:ui": "pnpm --filter @carecareer/platform-admin-console e2e:ui",
    "demo:e2e:debug": "pnpm --filter @carecareer/platform-admin-console e2e:debug",
    "demo:e2e:report": "pnpm --filter @carecareer/platform-admin-console e2e:report",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "2.27.12",
    "@typescript-eslint/eslint-plugin": "8.33.1",
    "@typescript-eslint/parser": "8.33.1",
    "eslint": "9.28.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-import": "2.31.0",
    "husky": "9.1.7",
    "lint-staged": "15.5.1",
    "prettier": "3.5.3",
    "turbo": "2.5.4",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vitest": "3.2.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
