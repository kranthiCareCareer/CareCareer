# =============================================================================
# CareCareer Platform — Environment Variables
# Copy to .env and fill in values
# =============================================================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://carecareer:carecareer_dev@localhost:5432/carecareer?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=carecareer_dev
MINIO_SECRET_KEY=carecareer_dev_secret
MINIO_BUCKET=carecareer-documents

# Search (Meilisearch)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=carecareer_dev_key

# Auth (JWT — local development)
JWT_SECRET=dev-only-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI (Model Router — use OpenAI for local dev, Bedrock in production)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
# AWS Bedrock (production — uncomment when deploying)
# AI_PROVIDER=bedrock
# AWS_REGION=us-east-1

# Email (Mailpit for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@carecareer.local

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:4000,http://localhost:4001,http://localhost:4002

# Notifications (future — AWS SNS/SES in production)
# SNS_TOPIC_ARN=
# SES_REGION=us-east-1

# Agent Core (future — AWS Bedrock AgentCore in production)
# AGENTCORE_ENDPOINT=
# AGENTCORE_GATEWAY_ID=
