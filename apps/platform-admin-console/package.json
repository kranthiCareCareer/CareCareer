{
  "name": "@carecareer/platform-admin-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 4000",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4000",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test --project=chromium-regression",
    "e2e:smoke": "playwright test --project=chromium-pr",
    "e2e:chromium": "playwright test --project=chromium-regression",
    "e2e:cross-browser": "playwright test --project=firefox-nightly --project=webkit-nightly",
    "e2e:responsive": "playwright test --project=mobile-chrome-web --project=mobile-safari-web",
    "e2e:navigation": "playwright test --grep @navigation --project=chromium-regression",
    "e2e:accessibility": "playwright test --grep @accessibility --project=chromium-regression",
    "e2e:release": "playwright test --project=chrome-release --project=edge-release",
    "e2e:headed": "playwright test --headed --workers=1 --project=chromium-regression",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:record": "playwright codegen http://localhost:4000"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "7.6.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.1",
    "@playwright/test": "1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.15.21",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.5.2",
    "jsdom": "^29.1.1",
    "typescript": "5.8.3",
    "vite": "6.3.5",
    "vitest": "3.2.3"
  }
}
