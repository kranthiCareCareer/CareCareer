{
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:fix": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:unit": { "cache": false },
    "test:integration": { "cache": false },
    "test:coverage": { "cache": false },
    "test:e2e": { "cache": false, "dependsOn": ["build"] },
    "db:migrate": { "cache": false },
    "db:seed": { "cache": false },
    "db:reset": { "cache": false },
    "clean": { "cache": false }
  }
}
