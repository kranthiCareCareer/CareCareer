{
  "name": "@carecareer/staffing-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build-production.mjs",
    "build:typecheck": "tsc -p tsconfig.build.json",
    "dev": "tsx --env-file=.env src/main.ts",
    "lint": "eslint --config eslint.config.mjs src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.coverage.config.ts",
    "coverage:security-check": "node scripts/coverage-security-check.mjs",
    "openapi:validate": "vitest run src/openapi/openapi-validate.spec.ts",
    "db:migrate": "node scripts/migrate.mjs",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@carecareer/auth": "workspace:*",
    "@carecareer/config": "workspace:*",
    "@carecareer/database": "workspace:*",
    "@carecareer/events": "workspace:*",
    "@carecareer/idempotency": "workspace:*",
    "@carecareer/observability": "workspace:*",
    "@carecareer/request-context": "workspace:*",
    "@carecareer/service-core": "workspace:*",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "jose": "6.0.11",
    "pg": "8.13.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "uuid": "14.0.0",
    "zod": "3.25.36"
  },
  "devDependencies": {
    "@carecareer/testing": "workspace:*",
    "@nestjs/testing": "11.1.28",
    "@testcontainers/postgresql": "10.18.0",
    "@types/node": "22.15.21",
    "@types/pg": "8.11.11",
    "@types/supertest": "6.0.2",
    "esbuild": "^0.28.1",
    "supertest": "7.1.0",
    "testcontainers": "10.18.0",
    "typescript": "5.8.3",
    "vitest": "3.2.6"
  }
}
