    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@carecareer/auth": "workspace:*",
    "@carecareer/config": "workspace:*",
    "@carecareer/database": "workspace:*",
    "@carecareer/events": "workspace:*",
    "@carecareer/idempotency": "workspace:*",
    "@carecareer/observability": "workspace:*",
    "@carecareer/request-context": "workspace:*",
    "@carecareer/service-core": "workspace:*",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.28",
    "@types/node": "22.15.21",
    "typescript": "5.8.3",
    "vitest": "3.2.6"
  }
}
