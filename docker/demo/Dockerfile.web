# Frontend build and serve for local demo
FROM node:20-alpine AS build

RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

WORKDIR /app

# Copy workspace root files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY .npmrc .pnpmfile.cjs ./

# Copy all workspace packages (needed for pnpm install)
COPY packages/ packages/
COPY services/ services/
COPY apps/ apps/
COPY tooling/ tooling/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Build the frontend
RUN pnpm --filter @carecareer/platform-admin-console build

# ─── Production stage with nginx ───
FROM nginx:alpine AS production

# Copy built assets
COPY --from=build /app/apps/platform-admin-console/dist /usr/share/nginx/html

# SPA routing config
RUN printf 'server {\n\
  listen 80;\n\
  root /usr/share/nginx/html;\n\
  index index.html;\n\
  location / {\n\
    try_files $uri $uri/ /index.html;\n\
  }\n\
}\n' > /etc/nginx/conf.d/default.conf

EXPOSE 80

HEALTHCHECK --interval=10s --timeout=3s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://127.0.0.1:80/ || exit 1
