{
  "name": "@carecareer/testing",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
