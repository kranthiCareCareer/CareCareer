    "@carecareer/request-context": "workspace:*",
    "@carecareer/events": "workspace:*",
    "@carecareer/idempotency": "workspace:*",
    "@carecareer/auth": "workspace:*",
    "@testcontainers/postgresql": "10.18.0",
    "pg": "8.13.3",
    "testcontainers": "10.18.0"
  },
  "devDependencies": {
    "@types/node": "22.15.21",
    "@types/pg": "8.11.11",
    "typescript": "5.8.3",
    "vitest": "3.2.3"
  }
}
